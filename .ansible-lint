# https://github.com/ansible/ansible-lint/issues/457
skip_list:
  - '602'
  - skip_ansible_lint
  # Role targets Ansible 2.9 and uses short module names throughout; FQCN
  # updates would require touching every task file.
  - 'fqcn[action-core]'
  # Several defaults values (e.g. leaderServes: yes) are written verbatim into
  # ZooKeeper config files and must remain as bare YAML booleans.
  - 'yaml[truthy]'
  # Directory-creation tasks intentionally omit mode; permissions are
  # controlled by the owner/group parameters and system umask.
  - 'risky-file-permissions'
  # The repository directory is named ansible-role-zk-solr following Ansible
  # Galaxy naming conventions; the derived role name role-zk-solr contains
  # hyphens which don't pass strict Galaxy namespace validation.
  - 'role-name'
verbosity: 1
exclude_paths:
  # Legacy test playbook that references the role by a short name not resolvable
  # without the role installed in a roles path; Molecule is used for testing.
  - tests/
